import Linglib.Theories.Semantics.Alternatives.Source
import Linglib.Theories.Semantics.Alternatives.Pronounceable
import Linglib.Core.Tree

/-!
# Indirect alternatives
@cite{jeretic-bassi-gonzalez-yatsushiro-meyer-sauerland-2025}

A novel notion of pragmatic alternative introduced by Jeretič, Bassi,
Gonzalez, Yatsushiro, Meyer & Sauerland (2025) to account for
the anti-duality of French *tous*.

## Definition (paper eq 43)

A pronounceable parse tree `I` is an **indirect alternative** of `S` iff
there exists an *unpronounceable* alternative `S_X` of `S` (drawn from
some base alternative source — typically Katzir's structural alternatives)
such that:

1. `⟦I⟧ = ⟦S_X⟧` (semantic equivalence with the unpronounceable witness)
2. `size I ≤ size S` (no more complex than `S`)

## Application to French *tous*

The dual structure `tous les NP.dual` is generated by the grammar
(Katzir-substituting `pl` → `dual` in the number-feature slot of `les NP`),
but blocked from pronunciation by Avoid Ambiguity
(`Theories/Pragmatics/AvoidAmbiguity.lean`) because its phonological
realization coincides with the plural-marked *tous les NP*. The
pronounceable expression *les deux NP* ('the two NP') is semantically
equivalent to *tous les NP.dual* and at-most-as-complex (Katzir
node count). It is therefore an indirect alternative — and triggers
Maximize Presupposition, deriving anti-duality of *tous*.

The infrastructure is generic over the base alternative source, the
pronounceability predicate, and the meaning function. It composes with
`violatesMP` from `Alternatives.Structural`: pass `indirectFrom base
pron meaning` instead of the bare base source to obtain an MP rule
that competes with unpronounceable witnesses.

See `Phenomena/Presupposition/Studies/JereticEtAl2025.lean` for the
empirical applications.
-/

set_option autoImplicit false

namespace Alternatives.Indirect

universe u v

open Alternatives
open Core.Tree

/-- The indirect-alternative relation (paper eq 43).

`IsIndirectAltOf base pron meaning size s' s` holds iff `s'` is at
most as complex as `s` and there is an unpronounceable `s_X ∈ base s`
with the same meaning as `s'`.

Parameters:
- `base`: the underlying alternative source (e.g. Katzir).
- `pron`: pronounceability predicate.
- `meaning`: the semantic interpretation function.
- `size`: complexity measure (e.g. `Tree.size`).
-/
def IsIndirectAltOf {S M : Type u}
    (base : AlternativeSource S) (pron : S → Prop)
    (meaning : S → M) (size : S → Nat)
    (s' s : S) : Prop :=
  size s' ≤ size s ∧ ∃ sX ∈ base s, ¬ pron sX ∧ meaning s' = meaning sX

/-- Lift the indirect-alternative relation to an `AlternativeSource`,
suitable for plugging into `violatesMP` (see
`Alternatives.Structural.violatesMP`). -/
def indirectFrom {S M : Type u}
    (base : AlternativeSource S) (pron : S → Prop)
    (meaning : S → M) (size : S → Nat) :
    AlternativeSource S :=
  fun s => {s' | IsIndirectAltOf base pron meaning size s' s}

/-- Convenience constructor for the common Tree case: pulls
pronounceability and size from the available typeclass / `Tree.size`. -/
def indirectFromTree {C W M : Type}
    [HasPronounceability (Tree C W)]
    (base : AlternativeSource (Tree C W))
    (meaning : Tree C W → M) :
    AlternativeSource (Tree C W) :=
  indirectFrom base (fun s => pronounceable s) meaning Tree.size

/-- Indirect alternatives are at most as complex as the original.
Direct consequence of the `size s' ≤ size s` clause in the definition. -/
theorem indirect_size_le {S M : Type u}
    {base : AlternativeSource S} {pron : S → Prop}
    {meaning : S → M} {size : S → Nat}
    {s' s : S} (h : s' ∈ indirectFrom base pron meaning size s) :
    size s' ≤ size s := h.1

/-- Indirect alternatives have the same meaning as some unpronounceable
witness in the base source. -/
theorem indirect_meaning_eq_witness {S M : Type u}
    {base : AlternativeSource S} {pron : S → Prop}
    {meaning : S → M} {size : S → Nat}
    {s' s : S} (h : s' ∈ indirectFrom base pron meaning size s) :
    ∃ sX ∈ base s, ¬ pron sX ∧ meaning s' = meaning sX := h.2

/-- An indirect alternative is *not* itself unpronounceable in general:
a pronounceable surrogate `s'` for an unpronounceable witness `sX` is
exactly the point of the construction. -/
theorem indirect_alt_witness_unpronounceable {S M : Type u}
    {base : AlternativeSource S} {pron : S → Prop}
    {meaning : S → M} {size : S → Nat}
    {s' s : S} (h : s' ∈ indirectFrom base pron meaning size s) :
    ∃ sX ∈ base s, ¬ pron sX :=
  match h.2 with
  | ⟨sX, hMem, hPron, _⟩ => ⟨sX, hMem, hPron⟩

/-- If a pronounceable witness `s'` ∈ `base s` exists with a given
meaning, it is its own indirect alternative *only if* the base source
is reflexive on `s'`; the indirect-alt machinery is for cases where
the *witness* `sX` is unpronounceable. This non-redundancy lemma
expresses the genuine refinement: an `s'` qualifies as indirect
alternative only via a silent witness, not by itself. -/
theorem indirect_requires_silent_witness {S M : Type u}
    {base : AlternativeSource S} {pron : S → Prop}
    {meaning : S → M} {size : S → Nat}
    {s' s : S} (h : s' ∈ indirectFrom base pron meaning size s)
    (allPron : ∀ x ∈ base s, pron x) : False :=
  match h.2 with
  | ⟨sX, hMem, hPron, _⟩ => hPron (allPron sX hMem)

end Alternatives.Indirect
