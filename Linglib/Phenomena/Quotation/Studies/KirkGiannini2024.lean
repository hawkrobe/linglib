import Linglib.Theories.Semantics.Quotation.MixedQuotation

/-!
# Kirk-Giannini 2024: Covert Mixed Quotation
@cite{kirk-giannini-2024}

Covert mixed quotation. Semantics and Pragmatics 17, Article 5: 1-54.

## Overview

Five apparently distinct phenomena are unified as manifestations of
covert mixed quotation — mixed quotation in the absence of overt
quotation marks:

1. **CI projection failure** (§3): Conventional implicature items
   (expressives, slurs, NRRCs) fail to project out of indirect speech
   reports and attitude ascriptions when the embedding involves quotation.

2. **C-monsters** (§4): Expressions like 'planet' in "Pluto could have
   been a planet" access the meaning the word would have under different
   linguistic conventions, via the diagonalizer †.

3. **Metalinguistic negation** (§5): "I didn't trap two MONGEESE — I
   trapped two MONGOOSES" negates not the proposition but the
   appropriateness of the expression, via 𝔄 + ↓ + negation.

4. **Metalinguistic negotiation** (§6): "Secretariat is an athlete" /
   "No, Secretariat is not an athlete" — the dispute targets whether
   it's appropriate to use 'athlete' for a horse, not whether Secretariat
   has the relevant properties. Same mechanism as §5 without negation.

5. **"In a sense"** (§7): "Viruses are alive in a sense" quantifies over
   speakers/intensions via binding 𝔐's free speaker variable.

## Scope

This module formalizes all five applications over finite models and
proves the key semantic predictions. Each section defines a concrete
scenario and verifies that the covert mixed quotation analysis derives
the correct truth conditions.

## Note on Denial Taxonomy

The three-way `DenialType` taxonomy (propositional / presuppositional /
implicature) from @cite{van-der-sandt-maier-2003} groups register and
connotation denials under `implicature`. Kirk-Giannini's analysis
suggests these are structurally distinct: metalinguistic negation targets
use-conditional appropriateness content generated by covert quotation,
not scalar implicature enrichment.
-/

set_option autoImplicit false

namespace KirkGiannini2024

open Semantics.Quotation
open Pragmatics.Expressives (TwoDimProp)

-- ════════════════════════════════════════════════════
-- § 1. CI Projection Failure (§3)
-- ════════════════════════════════════════════════════

section CIProjection

/-- Embedding contexts for CI projection tests. -/
inductive Embed where
  | unembedded | negation | question | indirectSpeech | attitude
  deriving DecidableEq, Repr

/-- CI projection data: whether CI content projects in each context.

    Standard view (@cite{potts-2005}): CIs project from ALL contexts.
    Kirk-Giannini's refinement: CIs fail to project when the embedding
    involves (covert) quotation — specifically indirect speech and
    certain attitude ascriptions. -/
structure CIProjectionDatum where
  sentence : String
  embed : Embed
  ciProjects : Bool
  notes : String := ""
  deriving Repr

/-- (20): "I didn't see that bastard Jones" — CI projects through negation. -/
def bastard_negation : CIProjectionDatum :=
  { sentence := "I didn't see that bastard Jones on my way to work"
  , embed := .negation
  , ciProjects := true
  , notes := "Speaker has negative attitude toward Jones" }

/-- (21): "Did you see Smith, who has eleven toes?" — CI projects through question. -/
def nrrc_question : CIProjectionDatum :=
  { sentence := "Did you see Smith, who has eleven toes, on your way to work?"
  , embed := .question
  , ciProjects := true
  , notes := "Speaker believes Smith has eleven toes" }

/-- (26): "Jones complained...looking for his goddamned keys" — CI does NOT project. -/
def expressive_noProject : CIProjectionDatum :=
  { sentence := "Jones complained all day that he'd had to spend an hour looking for his goddamned keys"
  , embed := .indirectSpeech
  , ciProjects := false
  , notes := "Jones (not speaker) has negative attitude; CI attributed to attitude holder" }

/-- (27): "My father screamed...Kraut Webster..." — CI does NOT project. -/
def slur_noProject : CIProjectionDatum :=
  { sentence := "My father screamed that he would never allow me to marry that Kraut Webster"
  , embed := .indirectSpeech
  , ciProjects := false
  , notes := "Father (not speaker) endorses slur; covert mixed quotation" }

/-- Kirk-Giannini's explanation: in non-projecting cases (26)-(27), the
    embedded material is first pure-quoted (stripping CIs including the
    expressive/slur content), then mixed-quoted (adding peripheral
    attribution to the attitude holder, not the speaker).

    The at-issue content of the mixed quotation contributes the reported
    proposition; the peripheral content attributes the utterance to the
    embedded subject. Since only at-issue content composes upward, the
    original CI never reaches the speaker. -/
theorem quotation_blocks_ci_projection (W : Type) (originalCI : (W → Bool))
    (atIssue : (W → Bool)) (w : W) :
    let withOrigCI := TwoDimProp.withCI atIssue originalCI
    let quoted := TwoDimProp.pureQuote withOrigCI
    -- After pure quotation, original CI is stripped
    quoted.ci w = true := rfl

/-- Concrete model for CI projection failure in indirect speech.

    (26): "Jones complained...looking for his goddamned keys"
    - 'goddamned' has expressive CI (negative attitude) in its original use
    - Under indirect speech, the embedded clause is covertly mixed-quoted
    - 𝔐 replaces the original CI with utterance attribution to Jones
    - The speaker's discourse is free of the expressive CI -/
inductive GDExpr where | goddamnedKeys deriving DecidableEq, Repr
inductive GDSpeaker where | jones | reporter deriving DecidableEq, Repr
inductive GDWorld where | actual deriving DecidableEq, Repr, Inhabited

/-- 'Goddamned keys' denotes: Jones spent an hour looking for his keys.
    The at-issue content is independent of speaker. -/
def gdInterp : QuotInterp GDExpr GDSpeaker GDWorld
  | .goddamnedKeys, _, _, _ => true

/-- Utterance relation: Jones produced the utterance, the reporter did not. -/
def gdUttRel : UttRel GDSpeaker Unit GDExpr GDWorld
  | .jones,    _, .goddamnedKeys, _ => true
  | .reporter, _, .goddamnedKeys, _ => false

/-- Jones is the attitude holder — 𝔐 attributes the utterance to Jones. -/
def gdCtx : MQContext GDWorld GDExpr GDSpeaker Unit :=
  { interp := gdInterp, uttRel := gdUttRel
  , sx := .jones, ux := (), wc := .actual }

/-- The full explanatory chain: 𝔐's output has Jones's utterance attribution
    as its peripheral content — NOT the original expressive CI. -/
theorem ci_replaced_by_attribution :
    (gdCtx.applyMQ .goddamnedKeys).ci .actual
    = gdUttRel .jones () .goddamnedKeys .actual := rfl

/-- The reporter is NOT attributed the utterance — the expressive CI
    ('goddamned') does not project to the reporter. -/
theorem reporter_not_attributed :
    gdUttRel .reporter () .goddamnedKeys .actual = false := rfl

/-- At-issue content is preserved: Jones spent an hour looking for his keys. -/
theorem atIssue_preserved :
    (gdCtx.applyMQ .goddamnedKeys).atIssue .actual = true := rfl

end CIProjection

-- ════════════════════════════════════════════════════
-- § 2. C-Monsters (§4)
-- ════════════════════════════════════════════════════

section CMonsters

/-- Worlds for the Pluto scenario.
    - `pre2006`: conventions classify Pluto as a planet
    - `post2006`: conventions do not classify Pluto as a planet -/
inductive PlutoWorld where
  | pre2006 | post2006
  deriving DecidableEq, Repr, Inhabited, BEq

/-- The word 'planet' as a quoted expression. -/
inductive PlutoExpr where
  | planet
  deriving DecidableEq, Repr

/-- A generic English speaker community. -/
inductive PlutoSpeaker where
  | english
  deriving DecidableEq, Repr

/-- Quotative interpretation for 'planet': its extension depends on
    the conventions operative at the world of utterance.

    At pre-2006 worlds: 'planet' picks out {Mercury, ..., Pluto}
    At post-2006 worlds: 'planet' picks out {Mercury, ..., Neptune}

    For simplicity we just track whether Pluto is in the extension. -/
def plutoPlanetInterp : QuotInterp PlutoExpr PlutoSpeaker PlutoWorld
  | .planet, .pre2006,  .english, _ => true   -- Pluto IS a planet under old conventions
  | .planet, .post2006, .english, _ => false   -- Pluto is NOT under new conventions

/-- Without diagonalization: ⟨planet⟩(wc)(s)(w) evaluates 'planet'
    relative to conventions at the world of context wc.

    If wc = post2006 (actual world), Pluto is not a planet at any w. -/
theorem without_diag_post2006 (w : PlutoWorld) :
    plutoPlanetInterp .planet .post2006 .english w = false := rfl

/-- With diagonalization: ⟨planet⟩(w)(s)(w) evaluates 'planet' relative
    to conventions at the world of evaluation w.

    At pre-2006 worlds, Pluto counts as a planet. This captures the
    c-monstrous reading of "Pluto could have been a planet" — the
    counterfactual accesses worlds where conventions still classify
    Pluto as a planet. -/
theorem with_diag_pre2006 :
    diagonalize plutoPlanetInterp .english .planet .pre2006 = true := rfl

theorem with_diag_post2006 :
    diagonalize plutoPlanetInterp .english .planet .post2006 = false := rfl

/-- (4): "Pluto could have easily been a planet."

    The diagonalizer † makes this true: there exist accessible worlds
    (pre-2006 convention worlds) where the diagonalized meaning of
    'planet' includes Pluto. No actual context-shifting monsters are
    needed (cf. `Theories.Semantics.Reference.Monsters.KaplansThesisHolds`),
    because † shifts which conventions are consulted, not the context. -/
theorem pluto_counterfactual_true :
    -- ∃ world where the diagonalized reading makes Pluto a planet
    ∃ w : PlutoWorld, diagonalize plutoPlanetInterp .english .planet w = true :=
  ⟨.pre2006, rfl⟩

end CMonsters

-- ════════════════════════════════════════════════════
-- § 3. Metalinguistic Negation (§5)
-- ════════════════════════════════════════════════════

section MetalinguisticNegation

/-- Expressions in the mongeese/mongooses scenario. -/
inductive MNExpr where
  | mongeese | mongooses
  deriving DecidableEq, Repr

/-- A single world (the actual world). -/
inductive MNWorld where
  | actual
  deriving DecidableEq, Repr, Inhabited

/-- A generic English speaker. -/
inductive MNSpeaker where
  | genericEnglish
  deriving DecidableEq, Repr

/-- Both 'mongeese' and 'mongooses' pick out the same property
    (being a mongoose) — they have identical at-issue content. -/
def mnInterp : QuotInterp MNExpr MNSpeaker MNWorld
  | .mongeese,  _, _, _ => true   -- mongoose property (same extension)
  | .mongooses, _, _, _ => true   -- mongoose property (same extension)

/-- Appropriateness: 'mongooses' is appropriate; 'mongeese' is not. -/
def mnApprop : AppropStandard MNSpeaker MNExpr MNWorld
  | _, .mongooses, _ => true
  | _, .mongeese,  _ => false

/-- The mixed quotation context for metalinguistic negation. -/
def mnCtx : MQContext MNWorld MNExpr MNSpeaker Unit :=
  { interp := mnInterp
  , uttRel := λ _ _ _ _ => true  -- utterance attribution is not load-bearing here
  , sx := .genericEnglish
  , ux := ()
  , wc := .actual }

/-- (3): "I didn't manage to trap two MONGEESE"

    Metalinguistic negation reading: ¬(I trapped mongooses ∧ appropriate
    to call them 'mongeese'). The at-issue content (I trapped mongooses)
    is true, but the appropriateness content ('mongeese' is appropriate)
    is false. So the negation is true.

    Compositional chain: 𝔐 → 𝔄 → ↓ → ¬. -/
theorem mongeese_metalinguistic_neg :
    (TwoDimProp.neg (shunt (applyApprop mnApprop mnCtx.sx .mongeese (mnCtx.applyMQ .mongeese)))).atIssue .actual
    = true := rfl

/-- "I managed to trap two MONGOOSES"

    The correcting clause: at-issue content is true AND it's appropriate
    to use 'mongooses'. Compositional chain: 𝔐 → 𝔄 → ↓. -/
theorem mongooses_appropriate :
    (shunt (applyApprop mnApprop mnCtx.sx .mongooses (mnCtx.applyMQ .mongooses))).atIssue .actual
    = true := rfl

/-- Key prediction: the metalinguistic negation reading targets
    appropriateness, not truth conditions. Both expressions have the
    same at-issue content via 𝔐 (mongoose property). -/
theorem same_atIssue_content :
    (mnCtx.applyMQ .mongeese).atIssue .actual
    = (mnCtx.applyMQ .mongooses).atIssue .actual := rfl

end MetalinguisticNegation

-- ════════════════════════════════════════════════════
-- § 4. Metalinguistic Negotiation (§6)
-- ════════════════════════════════════════════════════

section MetalinguisticNegotiation

/-- The word 'athlete' in the Secretariat dispute. -/
inductive AthExpr where
  | athlete
  deriving DecidableEq, Repr

/-- Two worlds: one where it's appropriate to call horses 'athletes',
    one where it's not. -/
inductive AthWorld where
  | broad  -- broad athleticism: horses count
  | narrow -- narrow athleticism: horses don't count
  deriving DecidableEq, Repr, Inhabited

/-- Two disputants. -/
inductive AthSpeaker where
  | speakerA | speakerB
  deriving DecidableEq, Repr

/-- Both speakers agree on the at-issue content: Secretariat has the
    relevant physical properties (broad athleticism). -/
def athInterp : QuotInterp AthExpr AthSpeaker AthWorld
  | .athlete, _, _, _ => true  -- Secretariat instantiates broad athleticism

/-- A's appropriateness standard: it IS appropriate to call a horse 'athlete'. -/
def athAppropA : AppropStandard AthSpeaker AthExpr AthWorld
  | _, .athlete, _ => true

/-- B's appropriateness standard: it is NOT appropriate to call a horse 'athlete'. -/
def athAppropB : AppropStandard AthSpeaker AthExpr AthWorld
  | _, .athlete, _ => false

/-- A's mixed quotation context. -/
def athCtxA : MQContext AthWorld AthExpr AthSpeaker Unit :=
  { interp := athInterp, uttRel := λ _ _ _ _ => true
  , sx := .speakerA, ux := (), wc := .broad }

/-- (6) A: "Secretariat is an athlete."

    On Kirk-Giannini's analysis, A's utterance is true iff
    (Secretariat has broad athleticism) ∧ (appropriate to use 'athlete').
    Under A's appropriateness standard, both conjuncts hold. -/
theorem speakerA_assertion :
    (shunt (applyApprop athAppropA athCtxA.sx .athlete (athCtxA.applyMQ .athlete))).atIssue .broad
    = true := rfl

/-- (6) B: "No, Secretariat is not an athlete."

    B's denial is metalinguistic negation: ¬(broad athleticism ∧
    appropriate to use 'athlete'). Under B's standard, the
    appropriateness conjunct is false, so the negation is true —
    even though B agrees Secretariat has broad athleticism. -/
theorem speakerB_denial :
    (TwoDimProp.neg (shunt (applyApprop athAppropB athCtxA.sx .athlete (athCtxA.applyMQ .athlete)))).atIssue .broad
    = true := rfl

/-- The disagreement is genuine: A's assertion and B's denial have
    incompatible truth values, because they operate under different
    appropriateness standards for the same expression. -/
theorem genuine_disagreement :
    (shunt (applyApprop athAppropA athCtxA.sx .athlete (athCtxA.applyMQ .athlete))).atIssue .broad
    ≠ (shunt (applyApprop athAppropB athCtxA.sx .athlete (athCtxA.applyMQ .athlete))).atIssue .broad := by
  decide

end MetalinguisticNegotiation

-- ════════════════════════════════════════════════════
-- § 5. "In a Sense" Constructions (§7)
-- ════════════════════════════════════════════════════

section InASense

/-- Expressions for the "viruses are alive" scenario. -/
inductive VirExpr where
  | alive
  deriving DecidableEq, Repr

/-- Two speakers with different intensions for 'alive':
    - biologist: 'alive' means "has genetic material" (viruses qualify)
    - layperson: 'alive' means "is in one of 5 kingdoms" (viruses don't) -/
inductive VirSpeaker where
  | biologist | layperson
  deriving DecidableEq, Repr

/-- A single world for simplicity. -/
inductive VirWorld where
  | actual
  deriving DecidableEq, Repr, Inhabited

/-- The quotative interpretation: 'alive' means different things
    depending on who is speaking.

    Biologist: viruses are alive (genetic material criterion)
    Layperson: viruses are not alive (5 kingdoms criterion) -/
def virInterp : QuotInterp VirExpr VirSpeaker VirWorld
  | .alive, _, .biologist, _ => true   -- alive under biological criterion
  | .alive, _, .layperson, _ => false  -- not alive under folk criterion

/-- MQ context parameterized by speaker — "in a sense" quantifies over
    the speaker variable of 𝔐, binding its free discourse anaphor. -/
def virMQCtx (s : VirSpeaker) : MQContext VirWorld VirExpr VirSpeaker Unit :=
  { interp := virInterp
  , uttRel := λ _ _ _ _ => true
  , sx := s
  , ux := ()
  , wc := .actual }

/-- (7'): "There is a sense in which viruses are alive."

    Kirk-Giannini's analysis: ∃ speaker sₓ such that 𝔐ₛₓ(alive) is
    true at the at-issue level. Quantifying over speakers is quantifying
    over intensions, since different speakers/communities assign different
    intensions to the same expression.

    The biologist provides the witness: under their use of 'alive',
    viruses are alive. -/
theorem in_a_sense_alive :
    ∃ s : VirSpeaker, ((virMQCtx s).applyMQ .alive).atIssue .actual = true :=
  ⟨.biologist, rfl⟩

/-- The layperson's use of 'alive' does not include viruses. -/
theorem not_alive_layperson :
    ((virMQCtx .layperson).applyMQ .alive).atIssue .actual = false := rfl

/-- Not ALL senses make viruses alive — the existential is non-trivial. -/
theorem not_all_senses :
    ¬ (∀ s : VirSpeaker, ((virMQCtx s).applyMQ .alive).atIssue .actual = true) := by
  intro h
  have := h .layperson
  simp [virMQCtx, MQContext.applyMQ, virInterp] at this

end InASense

end KirkGiannini2024
