import Linglib.Syntax.Minimalist.Basic

set_option autoImplicit false

/-!
# Core Computational Structure of Merge — MCB §1.10
@cite{marcolli-chomsky-berwick-2025}

MCB §1.10 (book p. 92, "The Core Computational Structure of Merge")
characterizes the computational structure of `SyntacticObject` as the
free non-associative commutative magma generated by Merge from the
alphabet `SO_0` (= `LIToken ⊕ Nat` in our substrate, which carries
trace markers explicitly per `Basic.lean`'s docstring).

## Lemma 1.10.1 — universal property

`SO = Magma_{na,c}(SO_0, M)` (MCB Eq 1.1.2) is the free nonassociative
commutative magma on the alphabet `SO_0`. Concretely, for any
commutative magma `Y` and any leaf-assignment `f : SO_0 → Y`, there is
a unique magma homomorphism `φ : SO →ₙ* Y` extending `f`. The "single
variable" phrasing of MCB's `Magma_{na,c}({x})` (book p. 92) emphasizes
that the binary Merge operator is the *single* recursive operation
generating the free magma — the magma has no other operations.

In our substrate this is exactly `FreeCommMagma.liftHom` (from
`Core/Algebra/Free.lean`) instantiated at `SO_0 := LIToken ⊕ Nat`,
plus the standard structural-induction uniqueness.

## Prop 1.10.2 — `X = M(X, X)` fixed-point equation

Every `X : SyntacticObject` is either a leaf (lexical or trace) or a
Merge `l * r` of two simpler syntactic objects. This is the type-level
fixed-point equation `X = M(X, X)` characterizing `SO` as the smallest
type closed under `leaf`, `trace`, and `mul` — the destructor form of
the recursive type definition.

The same recursive shape appears in MCB Eq 1.17.2 as the combinatorial
Dyson-Schwinger equation `X = B^+(P(X))` (algebraic substrate in
`Core/Algebra/RootedTree/DysonSchwinger.lean`). MCB §1.17 draws the
parallel explicitly: linguistic Merge's fixed-point structure has the
same formal shape as the DS equation in perturbative QFT.

## Status

Sorry-free. Pure characterization theorems consuming the existing
`SyntacticObject := FreeCommMagma (LIToken ⊕ Nat)` substrate.
-/

namespace Minimalist

namespace SyntacticObject

/-! ## §1: Lemma 1.10.1 — universal property of SO as free CommMagma

For any commutative magma `Y` and any leaf-assignment `f : LIToken ⊕ Nat → Y`,
the lift `FreeCommMagma.liftHom f : SO →ₙ* Y` is the unique magma
homomorphism extending `f`. -/

variable {Y : Type*} [CommMagma Y]

/-- **MCB Lemma 1.10.1** (existence half): every leaf-assignment
    `f : SO_0 → Y` extends to a magma homomorphism `SO →ₙ* Y`. -/
noncomputable def universalLift (f : LIToken ⊕ Nat → Y) :
    SyntacticObject →ₙ* Y :=
  FreeCommMagma.liftHom f

@[simp] theorem universalLift_of (f : LIToken ⊕ Nat → Y) (x : LIToken ⊕ Nat) :
    universalLift f (FreeCommMagma.of x) = f x := rfl

@[simp] theorem universalLift_leaf (f : LIToken ⊕ Nat → Y) (tok : LIToken) :
    universalLift f (.leaf tok) = f (Sum.inl tok) := rfl

@[simp] theorem universalLift_trace (f : LIToken ⊕ Nat → Y) (n : Nat) :
    universalLift f (.trace n) = f (Sum.inr n) := rfl

@[simp] theorem universalLift_mul (f : LIToken ⊕ Nat → Y)
    (l r : SyntacticObject) :
    universalLift f (l * r) = universalLift f l * universalLift f r :=
  MulHom.map_mul (universalLift f) l r

/-- **MCB Lemma 1.10.1** (uniqueness half): any two magma homomorphisms
    `SO →ₙ* Y` agreeing on leaves are equal. By structural induction. -/
theorem universalLift_unique (φ ψ : SyntacticObject →ₙ* Y)
    (h_leaves : ∀ x : LIToken ⊕ Nat, φ (FreeCommMagma.of x) = ψ (FreeCommMagma.of x)) :
    φ = ψ := by
  apply MulHom.ext
  intro X
  induction X with
  | leaf tok => exact h_leaves (Sum.inl tok)
  | trace n => exact h_leaves (Sum.inr n)
  | mul l r ihl ihr =>
    rw [MulHom.map_mul, MulHom.map_mul, ihl, ihr]

/-- **MCB Lemma 1.10.1** (combined existence + uniqueness): the magma
    homomorphism extending a leaf-assignment is unique. Surfaces the
    universal property of `SO` as the free nonassociative commutative
    magma on `SO_0`. -/
theorem mcb_1_10_1 (f : LIToken ⊕ Nat → Y) :
    ∃! (φ : SyntacticObject →ₙ* Y),
      ∀ x : LIToken ⊕ Nat, φ (FreeCommMagma.of x) = f x := by
  refine ⟨universalLift f, ?_, ?_⟩
  · intro x; rfl
  · intro ψ h_ψ
    exact (universalLift_unique ψ (universalLift f)
      (fun x => (h_ψ x).trans (universalLift_of f x).symm))

/-! ## §2: Prop 1.10.2 — `X = M(X, X)` fixed-point cases

Every `SyntacticObject` falls into one of three constructor cases:
lexical leaf, trace marker, or Merge of two simpler syntactic objects.
This is the destructor form of MCB Eq 1.17.3's `X = M(X, X)` —
recognizing that the algebraic `M(X, X)` summand corresponds to the
`l * r` constructor of `FreeCommMagma` (modulo the leaf/trace cases). -/

/-- **MCB Prop 1.10.2** (cases form): every `X : SyntacticObject` is a
    lexical leaf, a trace, or the Merge of two syntactic objects.

    This is the destructor form of the recursive fixed-point equation
    `X = M(X, X)` (Eq 1.17.3): if `X` is not a leaf or trace, then it
    decomposes as `X = l * r` for some `l, r : SyntacticObject`. -/
theorem mcb_1_10_2_cases (X : SyntacticObject) :
    (∃ tok, X = .leaf tok) ∨ (∃ n, X = .trace n) ∨
    (∃ l r : SyntacticObject, X = l * r) := by
  induction X with
  | leaf tok => exact Or.inl ⟨tok, rfl⟩
  | trace n => exact Or.inr (Or.inl ⟨n, rfl⟩)
  | mul l r _ _ => exact Or.inr (Or.inr ⟨l, r, rfl⟩)

/-- A `SyntacticObject` is either a leaf-or-trace or a Merge node.
    Refines `mcb_1_10_2_cases` using the `isNode` predicate. -/
theorem isNode_or_isLeafOrTrace (X : SyntacticObject) :
    isNode X ∨ isLeaf X := by
  induction X with
  | leaf _ => exact Or.inr trivial
  | trace _ => exact Or.inr trivial
  | mul l r _ _ => exact Or.inl (isNode_mul l r)

/-- **Recursion principle** for `SyntacticObject` mirroring `X = M(X, X)`:
    to define a function `SO → Y` (when `Y` is a `CommMagma`), it
    suffices to assign each leaf and Merge two values together. This is
    the dependent / definitional form of `mcb_1_10_1`: build the
    homomorphism by recursion on `X`'s structure. -/
noncomputable def recOnMerge {Y : Type*} [CommMagma Y]
    (f : LIToken ⊕ Nat → Y) (X : SyntacticObject) : Y :=
  universalLift f X

@[simp] theorem recOnMerge_leaf {Y : Type*} [CommMagma Y]
    (f : LIToken ⊕ Nat → Y) (tok : LIToken) :
    recOnMerge f (.leaf tok) = f (Sum.inl tok) := rfl

@[simp] theorem recOnMerge_trace {Y : Type*} [CommMagma Y]
    (f : LIToken ⊕ Nat → Y) (n : Nat) :
    recOnMerge f (.trace n) = f (Sum.inr n) := rfl

@[simp] theorem recOnMerge_mul {Y : Type*} [CommMagma Y]
    (f : LIToken ⊕ Nat → Y) (l r : SyntacticObject) :
    recOnMerge f (l * r) = recOnMerge f l * recOnMerge f r :=
  MulHom.map_mul (universalLift f) l r

/-! ## §3: Connection to MCB §1.17 (Dyson-Schwinger)

The fixed-point equation `X = M(X, X)` (MCB Eq 1.17.3) has the same
formal shape as the algebraic DS equation `X = B^+(P(X))` (Eq 1.17.2,
substrate in `Core/Algebra/RootedTree/DysonSchwinger.lean`):

* `B^+` (grafting a new root) on the algebra side ↔ Merge (combining
  into a new SO) on the linguistic side
* `P(X)` (polynomial input to the next iteration) ↔ `X * X` (pair of
  arguments to Merge)

In the algebraic substrate this parallel is captured by
`IsQuadDSSolution a X := X = bPlusLin a (X * X)`. The linguistic version
on `SyntacticObject` is more delicate: SO doesn't have an "extract two
copies of X" operation that produces a tensor; instead, the recursion
is in the type itself (every internal SO is `l * r` for some `l, r`),
which is exactly `mcb_1_10_2_cases`. -/

/-- **MCB Eq 1.17.3 (cases form)**: a `SyntacticObject` that is not a
    leaf or trace satisfies `X = l * r` for some `l, r` (where `*` is
    Merge). This is the linguistic-side analog of the algebraic DS
    equation `IsQuadDSSolution` (Eq 1.17.2). -/
theorem mcb_1_17_3_node_decomposes (X : SyntacticObject) (h : isNode X) :
    ∃ l r : SyntacticObject, X = l * r := by
  rcases mcb_1_10_2_cases X with ⟨tok, hX⟩ | ⟨n, hX⟩ | hmerge
  · exact absurd (hX ▸ h) (isNode_leaf tok)
  · exact absurd (hX ▸ h) (isNode_trace n)
  · exact hmerge

/-! ## §4: Sanity tests -/

/-- Sanity: the identity assignment lifts to the identity hom on SO. -/
example : (universalLift (FreeCommMagma.of (α := LIToken ⊕ Nat)) :
              SyntacticObject →ₙ* SyntacticObject) =
          MulHom.id SyntacticObject := by
  refine universalLift_unique _ _ ?_
  intro x
  show FreeCommMagma.of x = FreeCommMagma.of x
  rfl

/-- Sanity: `recOnMerge` evaluates the `size` of a small Merge expression
    (using `FreeCommMagma.size` from `Core/Algebra/Free.lean`). -/
example (tok₁ tok₂ : LIToken) :
    FreeCommMagma.size ((.leaf tok₁) * (.leaf tok₂) : SyntacticObject) = 3 := by
  rw [FreeCommMagma.size_mul, FreeCommMagma.size_of, FreeCommMagma.size_of]

end SyntacticObject

end Minimalist
