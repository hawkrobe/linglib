import Mathlib.Order.UpperLower.Basic
import Mathlib.Order.SupClosed
import Mathlib.Data.Finset.Basic
import Mathlib.Data.Finset.Lattice.Union

/-!
# Mathlib-grounded team-set closure substrate

@cite{anttila-2021} @cite{vaananen-2007}

The deep mathematical content of `Core/Logic/Team/Properties` re-expressed
as facts about subsets of `Finset őĪ` using mathlib's existing primitives:

| linglib name              | mathlib name                  |
|---------------------------|-------------------------------|
| `downwardClosed`-shape    | `IsLowerSet (T : Set (Finset őĪ))` |
| `unionClosed`-shape       | `SupClosed (T : Set (Finset őĪ))`  |
| `emptyTeam`-shape         | `‚ąÖ ‚ąą T`                       |
| `flat`-shape              | (defined below)               |

`Properties.lean`'s API is parameterised over `Model ‚Üí Form ‚Üí Finset őĪ ‚Üí
Prop` for consumer ergonomics, but the *content* of every closure-property
theorem reduces to a fact about `Set (Finset őĪ)` independent of formula
or model. This file states those facts at the parametric-content-free
level. `Properties.lean` becomes a thin wrapper exporting the consumer
form.

## Why this matters

The `Form/Model` parameters in `Properties.lean` are decorative: every
theorem `unionClosed support ŌÜ ‚ÜĒ ...` reduces to "the set
`{ t | support M ŌÜ t }` is `SupClosed`." Hoisting to the mathlib level
exposes:

1. **The theorem is about lattice structure on `Finset őĪ`**, not about
   logic. The flatness theorem is "principal lower set generated by
   atoms" ‚ÄĒ pure powerset combinatorics.
2. **Cross-carrier portability**: `Set őĪ` (used by `Question`) carries
   the same lattice structure (`Set őĪ` is a `CompleteBooleanAlgebra` with
   `‚äĒ = ‚ą™`, `‚ä• = ‚ąÖ`). The same flatness theorem holds for `Set (Set őĪ)`
   with mathlib `IsLowerSet` and arbitrary-union closure. The `Question`
   bridge in `Core/Question/Flatness.lean` is the `Set` carrier instance.
3. **No re-proof per consumer**: BSML, QBSML, and any future
   team-semantic logic with `Finset őĪ` carrier inherit the flatness
   theorem at zero substrate cost.

## Mathlib alignment

- `IsLowerSet (s : Set őĪ) [LE őĪ]` ‚ÄĒ `Mathlib.Order.Defs.Unbundled`. For
  `Finset őĪ`, the `LE` instance is `‚äÜ`.
- `SupClosed (s : Set őĪ) [SemilatticeSup őĪ]` ‚ÄĒ `Mathlib.Order.SupClosed`.
  For `Finset őĪ`, `‚äĒ = ‚ą™`.
- `Finset őĪ` is a `SemilatticeSup` with `OrderBot` (`‚ä• = ‚ąÖ`), so all
  three predicates apply directly.
-/

namespace Core.Logic.Team

variable {őĪ : Type*} [DecidableEq őĪ]

-- ============================================================================
-- ¬ß1 The team-set type
-- ============================================================================

/-- A **team-set**: a subset of teams (each team is a `Finset őĪ`).

    Equivalently, the extension of a team-semantic predicate at a fixed
    model + formula: `{ t : Finset őĪ | support M ŌÜ t }`. -/
abbrev TeamSet (őĪ : Type*) := Set (Finset őĪ)

-- ============================================================================
-- ¬ß2 Flatness
-- ============================================================================

/-- A team-set `T` is **flat** iff its membership reduces pointwise:
    `s ‚ąą T ‚ÜĒ every singleton drawn from s is in T`.

    Anttila Definition 2.2.1 (using "for all w ‚ąą s" ‚ÄĒ the standard
    Yang-V√§√§n√§nen formulation).

    Equivalently: `T` is the principal lower set generated by its
    singletons (proved by `isTeamFlat_iff_lower_supClosed_empty`). -/
def IsTeamFlat (T : TeamSet őĪ) : Prop :=
  ‚ąÄ s : Finset őĪ, s ‚ąą T ‚ÜĒ ‚ąÄ w ‚ąą s, ({w} : Finset őĪ) ‚ąą T

-- ============================================================================
-- ¬ß3 The flatness theorem (Anttila Prop 2.2.2 at substrate level)
-- ============================================================================

/-- **Anttila Proposition 2.2.2** at the substrate level: a team-set
    is flat iff it is downward-closed under inclusion (`IsLowerSet`),
    closed under binary union (`SupClosed`), and contains the empty team.

    No formula or model parameters ‚ÄĒ this is a pure lattice-theoretic
    fact about subsets of `Finset őĪ` under inclusion + union.

    The forward direction (flatness implies the three closure properties)
    is by case analysis on `s ‚ąą T`. The backward direction (the three
    properties imply flatness) inducts on `s` (Finset induction): empty
    case uses `HasEmpty`, insert case uses `SupClosed` to combine the
    singleton with the inductive hypothesis. -/
theorem isTeamFlat_iff_isLowerSet_supClosed_empty (T : TeamSet őĪ) :
    IsTeamFlat T ‚ÜĒ IsLowerSet T ‚ąß SupClosed T ‚ąß ‚ąÖ ‚ąą T := by
  constructor
  ¬∑ -- Flat ‚Üí all three closure properties
    intro hFlat
    refine ‚ü®?_, ?_, ?_‚ü©
    ¬∑ -- IsLowerSet: a ‚äÜ b ‚Üí b ‚ąą T ‚Üí a ‚ąą T (using Finset's ‚Č§ = ‚äÜ)
      intro a b hab hb
      rw [hFlat]
      intro w hwa
      rw [hFlat] at hb
      exact hb w (hab hwa)
    ¬∑ -- SupClosed: a ‚ąą T ‚Üí b ‚ąą T ‚Üí a ‚äĒ b ‚ąą T (where ‚äĒ = ‚ą™ on Finset)
      intro a ha b hb
      rw [hFlat]
      intro w hwab
      -- hwab : w ‚ąą a ‚äĒ b on Finset; ‚äĒ = ‚ą™.
      have hwab' : w ‚ąą a ‚ą™ b := hwab
      rw [Finset.mem_union] at hwab'
      cases hwab' with
      | inl hwa => rw [hFlat] at ha; exact ha w hwa
      | inr hwb => rw [hFlat] at hb; exact hb w hwb
    ¬∑ -- ‚ąÖ ‚ąą T: vacuously, no w ‚ąą ‚ąÖ
      rw [hFlat]
      intro w hw
      exact absurd hw (Finset.notMem_empty w)
  ¬∑ -- All three closure properties ‚Üí flat
    rintro ‚ü®hLower, hSup, hEmpty‚ü©
    intro s
    refine ‚ü®?_, ?_‚ü©
    ¬∑ -- s ‚ąą T ‚Üí every singleton from s in T (use IsLowerSet on {w} ‚äÜ s)
      intro hs w hw
      -- IsLowerSet on Finset uses Finset's ‚Č§ which is ‚äÜ.
      exact hLower (show ({w} : Finset őĪ) ‚Č§ s from
        Finset.singleton_subset_iff.mpr hw) hs
    ¬∑ -- Every singleton from s in T ‚Üí s ‚ąą T (induct on s using SupClosed + empty)
      intro hAll
      induction s using Finset.induction with
      | empty => exact hEmpty
      | @insert w t hwt ih =>
        have hsing : ({w} : Finset őĪ) ‚ąą T :=
          hAll w (Finset.mem_insert_self w t)
        have ht : t ‚ąą T :=
          ih (fun w' hw' => hAll w' (Finset.mem_insert_of_mem hw'))
        rw [show insert w t = ({w} : Finset őĪ) ‚ą™ t from
          (Finset.singleton_union w t).symm]
        exact hSup hsing ht

/-- **Backward direction extracted as a constructor**: the three closure
    properties imply flatness. The most-used direction in consumers. -/
theorem isTeamFlat_of_isLowerSet_supClosed_empty (T : TeamSet őĪ)
    (hLower : IsLowerSet T) (hSup : SupClosed T) (hEmpty : ‚ąÖ ‚ąą T) :
    IsTeamFlat T :=
  (isTeamFlat_iff_isLowerSet_supClosed_empty T).mpr ‚ü®hLower, hSup, hEmpty‚ü©

/-- **Forward extraction**: flat team-sets are downward-closed. -/
theorem IsTeamFlat.isLowerSet {T : TeamSet őĪ} (h : IsTeamFlat T) :
    IsLowerSet T := ((isTeamFlat_iff_isLowerSet_supClosed_empty T).mp h).1

/-- **Forward extraction**: flat team-sets are sup-closed. -/
theorem IsTeamFlat.supClosed {T : TeamSet őĪ} (h : IsTeamFlat T) :
    SupClosed T := ((isTeamFlat_iff_isLowerSet_supClosed_empty T).mp h).2.1

/-- **Forward extraction**: flat team-sets contain the empty team. -/
theorem IsTeamFlat.hasEmpty {T : TeamSet őĪ} (h : IsTeamFlat T) :
    ‚ąÖ ‚ąą T := ((isTeamFlat_iff_isLowerSet_supClosed_empty T).mp h).2.2

-- ============================================================================
-- ¬ß4 TeamPred őĪ: the predicate-of-team-membership form
-- ============================================================================

/-- A **team predicate**: a `Finset őĪ ‚Üí Prop`. Equivalent to `TeamSet őĪ` via
    set-builder, but more ergonomic for consumers who think of `support M ŌÜ`
    as a function from teams to propositions.

    The closure properties on a `TeamPred` are defined as the corresponding
    properties on `{ t | P t } : TeamSet őĪ`. -/
abbrev TeamPred (őĪ : Type*) := Finset őĪ ‚Üí Prop

namespace TeamPred

variable {őĪ : Type*} [DecidableEq őĪ]

/-- A team-predicate is **downward-closed** iff `{ t | P t }` is a lower set
    under inclusion. Wraps mathlib's `IsLowerSet`; the underlying definition
    is `‚ąÄ a b, a ‚äÜ b ‚Üí P b ‚Üí P a`. -/
def IsDownward (P : TeamPred őĪ) : Prop := IsLowerSet { t : Finset őĪ | P t }

/-- A team-predicate is **sup-closed** iff `{ t | P t }` is closed under
    binary union. Wraps mathlib's `SupClosed` (with `‚äĒ = ‚ą™` on `Finset`);
    underlying: `‚ąÄ a b, P a ‚Üí P b ‚Üí P (a ‚ą™ b)`. -/
def IsSupClosed (P : TeamPred őĪ) : Prop := SupClosed { t : Finset őĪ | P t }

/-- A team-predicate **has empty** iff the empty team satisfies it. -/
def HasEmpty (P : TeamPred őĪ) : Prop := P ‚ąÖ

/-- A team-predicate is **flat** iff its membership reduces pointwise:
    `P s ‚ÜĒ ‚ąÄ w ‚ąą s, P {w}`. Wraps `IsTeamFlat` on `{ t | P t }`. -/
def IsFlat (P : TeamPred őĪ) : Prop := IsTeamFlat { t : Finset őĪ | P t }

-- ============================================================================
-- ¬ß5 Anttila Prop 2.2.2 at the TeamPred level
-- ============================================================================

/-- **Anttila Proposition 2.2.2** in `TeamPred` form: a team-predicate is
    flat iff it is downward-closed, sup-closed, and has the empty team.
    Direct corollary of the `TeamSet`-level theorem. -/
theorem isFlat_iff (P : TeamPred őĪ) :
    P.IsFlat ‚ÜĒ P.IsDownward ‚ąß P.IsSupClosed ‚ąß P.HasEmpty := by
  unfold IsFlat IsDownward IsSupClosed HasEmpty
  exact isTeamFlat_iff_isLowerSet_supClosed_empty _

/-- Constructor: combine the three closure properties to get flatness. -/
theorem isFlat_of_isDownward_isSupClosed_hasEmpty (P : TeamPred őĪ)
    (h_down : P.IsDownward) (h_sup : P.IsSupClosed) (h_empty : P.HasEmpty) :
    P.IsFlat :=
  (isFlat_iff P).mpr ‚ü®h_down, h_sup, h_empty‚ü©

/-- Forward extraction: flat team-predicates are downward-closed. -/
theorem IsFlat.isDownward {P : TeamPred őĪ} (h : P.IsFlat) : P.IsDownward :=
  ((isFlat_iff P).mp h).1

/-- Forward extraction: flat team-predicates are sup-closed. -/
theorem IsFlat.isSupClosed {P : TeamPred őĪ} (h : P.IsFlat) : P.IsSupClosed :=
  ((isFlat_iff P).mp h).2.1

/-- Forward extraction: flat team-predicates have the empty team. -/
theorem IsFlat.hasEmpty {P : TeamPred őĪ} (h : P.IsFlat) : P.HasEmpty :=
  ((isFlat_iff P).mp h).2.2

-- ============================================================================
-- ¬ß6 Pointwise unfoldings (for proof ergonomics)
-- ============================================================================

/-- Pointwise form of `IsDownward`: a team-predicate is downward-closed iff
    `‚ąÄ a b, a ‚äÜ b ‚Üí P b ‚Üí P a`. Just unfolds `IsLowerSet` for the
    `{ t | P t }` instance ‚ÄĒ `Finset őĪ`'s `‚Č§` is `‚äÜ`. -/
theorem isDownward_iff_pointwise (P : TeamPred őĪ) :
    P.IsDownward ‚ÜĒ ‚ąÄ ‚¶Éa b : Finset őĪ‚¶Ą, a ‚äÜ b ‚Üí P b ‚Üí P a := by
  constructor
  ¬∑ intro h a b hab hb; exact h hab hb
  ¬∑ intro h a b hab hb; exact h hab hb

/-- Pointwise form of `IsSupClosed`: `‚ąÄ a b, P a ‚Üí P b ‚Üí P (a ‚ą™ b)`. -/
theorem isSupClosed_iff_pointwise (P : TeamPred őĪ) :
    P.IsSupClosed ‚ÜĒ ‚ąÄ ‚¶Éa‚¶Ą, P a ‚Üí ‚ąÄ ‚¶Éb‚¶Ą, P b ‚Üí P (a ‚ą™ b) := by
  constructor
  ¬∑ intro h a ha b hb; exact h ha hb
  ¬∑ intro h a ha b hb; exact h ha hb

/-- Pointwise form of `IsFlat`: `‚ąÄ s, P s ‚ÜĒ ‚ąÄ w ‚ąą s, P {w}`. -/
theorem isFlat_iff_pointwise (P : TeamPred őĪ) :
    P.IsFlat ‚ÜĒ ‚ąÄ s, P s ‚ÜĒ ‚ąÄ w ‚ąą s, P {w} := Iff.rfl

end TeamPred

end Core.Logic.Team
