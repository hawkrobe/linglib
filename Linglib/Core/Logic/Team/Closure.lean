import Mathlib.Order.UpperLower.Basic
import Mathlib.Order.SupClosed
import Mathlib.Data.Finset.Basic
import Mathlib.Data.Finset.Lattice.Union

/-!
# Team-set flatness — Anttila Proposition 2.2.2

@cite{anttila-2021} @cite{vaananen-2007}

A **team-set** is a `Set (Finset α)` — the extension of a team-semantic
predicate at a fixed model + formula, e.g. `{ t | support M φ t }`. This
file states Anttila Definition 2.2.1 (flatness) and Proposition 2.2.2
(the flatness characterisation) directly on `Set (Finset α)` using
mathlib's `IsLowerSet` and `SupClosed`.

## Main declarations

* `IsFlat` — a team-set is flat iff membership reduces pointwise:
  `s ∈ T ↔ every singleton from s is in T` (Anttila 2.2.1).
* `isFlat_iff` — Anttila Proposition 2.2.2: flatness is equivalent to the
  conjunction of `IsLowerSet T`, `SupClosed T`, and `∅ ∈ T`.
* `IsFlat.isLowerSet`, `IsFlat.supClosed`, `IsFlat.empty_mem` — forward
  extractions of the three closure properties from flatness.

## Implementation notes

The pointwise predicate `IsFlat` is `Finset α`-specific because it uses
singleton membership `{w} ∈ T`. Carrier polymorphism is available at the
lattice level: mathlib's `IsLowerSet`/`SupClosed` are already parametric
in `[LE _]`/`[SemilatticeSup _]`, so consumers with `Set α` or other
carriers can use those primitives directly without going through `IsFlat`.

Consumers state closure properties of `support M φ` per-`M` and per-`φ` as
mathlib-direct predicates on `{ t | support M φ t } : Set (Finset α)`:

```
theorem isSupClosed_support (M : BSMLModel W Atom) (φ : BSMLFormula Atom) :
    SupClosed { t | support M φ t }
```

No project-specific wrapper around `SupClosed`/`IsLowerSet` is needed.
-/

namespace Core.Logic.Team

variable {α : Type*} [DecidableEq α]

/-- A team-set `T : Set (Finset α)` is **flat** iff membership reduces
    pointwise: `s ∈ T ↔ every singleton from s is in T`.

    Anttila Definition 2.2.1 (using the standard "for all w ∈ s"
    Yang-Väänänen formulation). Equivalently, `T` is the principal lower
    set generated by its singletons — see `isFlat_iff`. -/
def IsFlat (T : Set (Finset α)) : Prop :=
  ∀ s : Finset α, s ∈ T ↔ ∀ w ∈ s, ({w} : Finset α) ∈ T

/-- **Anttila Proposition 2.2.2**: a team-set is flat iff it is
    downward-closed under inclusion (`IsLowerSet`), closed under binary
    union (`SupClosed`), and contains the empty team.

    Pure lattice-theoretic fact about subsets of `Finset α` under
    inclusion + union — no formula or model parameters.

    The forward direction is by case analysis on `s ∈ T`. The backward
    direction inducts on `s` using `Finset.induction`: empty case uses
    `∅ ∈ T`, insert case uses `SupClosed` to combine the singleton with
    the inductive hypothesis. -/
theorem isFlat_iff (T : Set (Finset α)) :
    IsFlat T ↔ IsLowerSet T ∧ SupClosed T ∧ ∅ ∈ T := by
  constructor
  · intro hFlat
    refine ⟨?_, ?_, ?_⟩
    · intro a b hab hb
      rw [hFlat]
      intro w hwa
      rw [hFlat] at hb
      exact hb w (hab hwa)
    · intro a ha b hb
      rw [hFlat]
      intro w hwab
      have hwab' : w ∈ a ∪ b := hwab
      rw [Finset.mem_union] at hwab'
      cases hwab' with
      | inl hwa => rw [hFlat] at ha; exact ha w hwa
      | inr hwb => rw [hFlat] at hb; exact hb w hwb
    · rw [hFlat]
      intro w hw
      exact absurd hw (Finset.notMem_empty w)
  · rintro ⟨hLower, hSup, hEmpty⟩
    intro s
    refine ⟨?_, ?_⟩
    · intro hs w hw
      exact hLower (show ({w} : Finset α) ≤ s from
        Finset.singleton_subset_iff.mpr hw) hs
    · intro hAll
      induction s using Finset.induction with
      | empty => exact hEmpty
      | @insert w t hwt ih =>
        have hsing : ({w} : Finset α) ∈ T :=
          hAll w (Finset.mem_insert_self w t)
        have ht : t ∈ T :=
          ih (fun w' hw' => hAll w' (Finset.mem_insert_of_mem hw'))
        rw [show insert w t = ({w} : Finset α) ∪ t from
          (Finset.singleton_union w t).symm]
        exact hSup hsing ht

/-- Constructor form of Anttila 2.2.2 — the most-used direction. -/
theorem isFlat_of_isLowerSet_supClosed_empty {T : Set (Finset α)}
    (hLower : IsLowerSet T) (hSup : SupClosed T) (hEmpty : ∅ ∈ T) :
    IsFlat T :=
  (isFlat_iff T).mpr ⟨hLower, hSup, hEmpty⟩

theorem IsFlat.isLowerSet {T : Set (Finset α)} (h : IsFlat T) : IsLowerSet T :=
  ((isFlat_iff T).mp h).1

theorem IsFlat.supClosed {T : Set (Finset α)} (h : IsFlat T) : SupClosed T :=
  ((isFlat_iff T).mp h).2.1

theorem IsFlat.empty_mem {T : Set (Finset α)} (h : IsFlat T) : ∅ ∈ T :=
  ((isFlat_iff T).mp h).2.2

end Core.Logic.Team
