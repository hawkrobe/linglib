import Mathlib.Order.Antisymmetrization
import Linglib.Core.Order.Ortholattice

/-!
# Orthologic: syntax, proof system, and algebraic completeness

[UPSTREAM] candidate.

Orthologic ([holliday-mandelkern-2024] §3.1, after Goldblatt) is the logic of
ortholattices: `φ ⊢ ψ` is the consequence relation holding in every
`OrthocomplementedLattice`. This file gives the syntax, Goldblatt's proof system
(Definition 3.12), and — via mathlib's `Antisymmetrization` (documented as *the*
free `Preorder → PartialOrder` functor) — the Lindenbaum–Tarski algebra
witnessing **algebraic completeness** (Theorem 3.13): the least orthologic is
sound and complete with respect to the class of all ortholattices.

## Main definitions

* `Formula` — orthologic formulas (`⊤`, variables, `¬`, `∧`; `∨` De Morgan-defined).
* `Derivable` (`⊢`) — the least orthologic (Goldblatt's ten rules).
* `LindenbaumTarski` — formulas modulo interderivability (an `OrthocomplementedLattice`).
* `eval`, soundness, completeness.

## Implementation notes

The Lindenbaum–Tarski algebra is `Antisymmetrization (Formula Var) (· ≤ ·)` for
the provability preorder; mathlib documents `Antisymmetrization` as the free
functor `Preord → PartOrd`, so the quotient and its `PartialOrder` come for free.
This file adds the `OrthocomplementedLattice` structure and completeness.
-/

namespace Orthologic

/-! ### Syntax -/

/-- Orthologic formulas over a variable type `Var`. Disjunction is De Morgan-defined
    (`Formula.or`), matching the ortholattice signature. -/
inductive Formula (Var : Type*) where
  | top : Formula Var
  | var (p : Var) : Formula Var
  | neg (φ : Formula Var) : Formula Var
  | and (φ ψ : Formula Var) : Formula Var

namespace Formula

variable {Var : Type*}

/-- De Morgan disjunction `φ ∨ ψ := ¬(¬φ ∧ ¬ψ)`. -/
def or (φ ψ : Formula Var) : Formula Var := neg (and (neg φ) (neg ψ))

/-- Falsum `⊥ := ¬⊤`. -/
def bot : Formula Var := neg top

end Formula

/-! ### The proof system -/

/-- The least **orthologic** ([holliday-mandelkern-2024] Definition 3.12, after
    Goldblatt): `Derivable φ ψ` (written `φ ⊢ ψ`) is generated by ten rules —
    `⊤`-introduction, reflexivity, the two `∧`-projections, double-negation
    introduction and elimination, non-contradiction (`φ ∧ ¬φ ⊢ ψ`), cut,
    `∧`-introduction, and contraposition. -/
inductive Derivable {Var : Type*} : Formula Var → Formula Var → Prop where
  | top_intro (φ) : Derivable φ .top
  | refl (φ) : Derivable φ φ
  | and_le_left (φ ψ) : Derivable (.and φ ψ) φ
  | and_le_right (φ ψ) : Derivable (.and φ ψ) ψ
  | le_negNeg (φ) : Derivable φ (.neg (.neg φ))
  | negNeg_le (φ) : Derivable (.neg (.neg φ)) φ
  | contradiction (φ ψ) : Derivable (.and φ (.neg φ)) ψ
  | trans {φ ψ χ} : Derivable φ ψ → Derivable ψ χ → Derivable φ χ
  | le_and {φ ψ χ} : Derivable φ ψ → Derivable φ χ → Derivable φ (.and ψ χ)
  | neg_le_neg {φ ψ} : Derivable φ ψ → Derivable (.neg ψ) (.neg φ)

@[inherit_doc] scoped infix:50 " ⊢ " => Derivable

/-! ### The provability preorder and the Lindenbaum–Tarski algebra -/

/-- Provability is a preorder (reflexivity + cut). -/
instance instPreorder {Var : Type*} : Preorder (Formula Var) where
  le := Derivable
  le_refl := Derivable.refl
  le_trans _ _ _ h := h.trans

/-- The **Lindenbaum–Tarski algebra**: formulas modulo interderivability. As the
    `Antisymmetrization` of the provability preorder it is automatically a
    `PartialOrder`; the `OrthocomplementedLattice` structure is added below. -/
abbrev LindenbaumTarski (Var : Type*) : Type _ :=
  Antisymmetrization (Formula Var) (· ≤ ·)

/-! ### Evaluation and soundness -/

variable {Var : Type*} {L : Type*} [OrthocomplementedLattice L]

/-- Evaluate a formula in an ortholattice under a valuation `v : Var → L`. -/
def Formula.eval (v : Var → L) : Formula Var → L
  | .top => ⊤
  | .var p => v p
  | .neg φ => (Formula.eval v φ)ᶜ
  | .and φ ψ => Formula.eval v φ ⊓ Formula.eval v ψ

/-- **Soundness**: a derivable consequence holds in every ortholattice under
    every valuation ([holliday-mandelkern-2024] Theorem 3.13, soundness half). -/
theorem sound {φ ψ : Formula Var} (h : φ ⊢ ψ) (v : Var → L) :
    Formula.eval v φ ≤ Formula.eval v ψ := by
  induction h with
  | top_intro φ => exact le_top
  | refl φ => exact le_refl _
  | and_le_left φ ψ => exact inf_le_left
  | and_le_right φ ψ => exact inf_le_right
  | le_negNeg φ => exact (LatticeWithInvolution.compl_compl _).ge
  | negNeg_le φ => exact (LatticeWithInvolution.compl_compl _).le
  | contradiction φ ψ => exact (OrthocomplementedLattice.inf_compl_eq_bot _).le.trans bot_le
  | trans _ _ ih₁ ih₂ => exact ih₁.trans ih₂
  | le_and _ _ ih₁ ih₂ => exact le_inf ih₁ ih₂
  | neg_le_neg _ ih => exact LatticeWithInvolution.compl_le_compl ih

/-! ### Provability lemmas for the lattice structure

These are the ortholattice axioms at the level of formulas; the quotient
instance below lifts them through `Antisymmetrization`. -/

namespace Formula

variable {Var : Type*}

/-- `⊥ ⊢ φ` (ex falso, with `⊥ = ¬⊤`). -/
theorem bot_le (φ : Formula Var) : bot ⊢ φ :=
  (Derivable.le_and (Derivable.top_intro bot) (Derivable.refl bot)).trans
    (Derivable.contradiction top φ)

/-- Conjunction is monotone. -/
theorem and_mono {φ φ' ψ ψ' : Formula Var} (h₁ : φ ⊢ φ') (h₂ : ψ ⊢ ψ') :
    and φ ψ ⊢ and φ' ψ' :=
  Derivable.le_and ((Derivable.and_le_left φ ψ).trans h₁) ((Derivable.and_le_right φ ψ).trans h₂)

/-- `φ ⊢ φ ∨ ψ`. -/
theorem le_or_left (φ ψ : Formula Var) : φ ⊢ or φ ψ :=
  (Derivable.le_negNeg φ).trans (Derivable.neg_le_neg (Derivable.and_le_left (neg φ) (neg ψ)))

/-- `ψ ⊢ φ ∨ ψ`. -/
theorem le_or_right (φ ψ : Formula Var) : ψ ⊢ or φ ψ :=
  (Derivable.le_negNeg ψ).trans (Derivable.neg_le_neg (Derivable.and_le_right (neg φ) (neg ψ)))

/-- `φ ∨ ψ ⊢ χ` from `φ ⊢ χ` and `ψ ⊢ χ`. -/
theorem or_le {φ ψ χ : Formula Var} (h₁ : φ ⊢ χ) (h₂ : ψ ⊢ χ) : or φ ψ ⊢ χ :=
  (Derivable.neg_le_neg (Derivable.le_and (Derivable.neg_le_neg h₁) (Derivable.neg_le_neg h₂))).trans
    (Derivable.negNeg_le χ)

/-- Disjunction is monotone. -/
theorem or_mono {φ φ' ψ ψ' : Formula Var} (h₁ : φ ⊢ φ') (h₂ : ψ ⊢ ψ') :
    or φ ψ ⊢ or φ' ψ' :=
  or_le (h₁.trans (le_or_left φ' ψ')) (h₂.trans (le_or_right φ' ψ'))

/-- Non-contradiction: `φ ∧ ¬φ ⊢ ⊥`. -/
theorem and_compl_le_bot (φ : Formula Var) : and φ (neg φ) ⊢ bot :=
  Derivable.contradiction φ bot

/-- Excluded middle: `⊤ ⊢ φ ∨ ¬φ`. -/
theorem top_le_or_compl (φ : Formula Var) : (top : Formula Var) ⊢ or φ (neg φ) :=
  (Derivable.le_negNeg top).trans (Derivable.neg_le_neg (Derivable.contradiction (neg φ) (neg top)))

end Formula

/-! ### The Lindenbaum–Tarski algebra is an ortholattice -/

namespace LindenbaumTarski

variable {Var : Type*}

instance : Min (LindenbaumTarski Var) where
  min := Quotient.map₂ Formula.and
    fun _ _ h₁ _ _ h₂ => ⟨Formula.and_mono h₁.1 h₂.1, Formula.and_mono h₁.2 h₂.2⟩

instance : Max (LindenbaumTarski Var) where
  max := Quotient.map₂ Formula.or
    fun _ _ h₁ _ _ h₂ => ⟨Formula.or_mono h₁.1 h₂.1, Formula.or_mono h₁.2 h₂.2⟩

instance : Compl (LindenbaumTarski Var) where
  compl := Quotient.map Formula.neg fun _ _ h => ⟨Derivable.neg_le_neg h.2, Derivable.neg_le_neg h.1⟩

instance : Top (LindenbaumTarski Var) where
  top := toAntisymmetrization (· ≤ ·) Formula.top

instance : Bot (LindenbaumTarski Var) where
  bot := toAntisymmetrization (· ≤ ·) Formula.bot

/-- `⟦φ⟧ ≤ ⟦ψ⟧` in the Lindenbaum–Tarski algebra iff `φ ⊢ ψ`. -/
theorem mk_le_mk {x y : Formula Var} :
    toAntisymmetrization (· ≤ ·) x ≤ toAntisymmetrization (· ≤ ·) y ↔ x ⊢ y :=
  toAntisymmetrization_le_toAntisymmetrization_iff

instance : Lattice (LindenbaumTarski Var) where
  inf := (· ⊓ ·)
  sup := (· ⊔ ·)
  inf_le_left a b := Quotient.inductionOn₂ a b fun x y => mk_le_mk.mpr (Derivable.and_le_left x y)
  inf_le_right a b := Quotient.inductionOn₂ a b fun x y => mk_le_mk.mpr (Derivable.and_le_right x y)
  le_inf a b c := Quotient.inductionOn₃ a b c fun _ _ _ hxy hxz =>
    mk_le_mk.mpr (Derivable.le_and (mk_le_mk.mp hxy) (mk_le_mk.mp hxz))
  le_sup_left a b := Quotient.inductionOn₂ a b fun x y => mk_le_mk.mpr (Formula.le_or_left x y)
  le_sup_right a b := Quotient.inductionOn₂ a b fun x y => mk_le_mk.mpr (Formula.le_or_right x y)
  sup_le a b c := Quotient.inductionOn₃ a b c fun _ _ _ hxz hyz =>
    mk_le_mk.mpr (Formula.or_le (mk_le_mk.mp hxz) (mk_le_mk.mp hyz))

instance : BoundedOrder (LindenbaumTarski Var) where
  le_top a := Quotient.inductionOn a fun x => mk_le_mk.mpr (Derivable.top_intro x)
  bot_le a := Quotient.inductionOn a fun x => mk_le_mk.mpr (Formula.bot_le x)

/-- The Lindenbaum–Tarski algebra of orthologic is an orthocomplemented lattice. -/
instance : OrthocomplementedLattice (LindenbaumTarski Var) where
  compl_compl a := Quotient.inductionOn a fun x =>
    Quotient.sound ⟨Derivable.negNeg_le x, Derivable.le_negNeg x⟩
  compl_le_compl {a b} := Quotient.inductionOn₂ a b
    (fun _ _ h => mk_le_mk.mpr (Derivable.neg_le_neg (mk_le_mk.mp h)))
  inf_compl_le_bot a := Quotient.inductionOn a fun x => mk_le_mk.mpr (Formula.and_compl_le_bot x)
  top_le_sup_compl a := Quotient.inductionOn a fun x => mk_le_mk.mpr (Formula.top_le_or_compl x)

end LindenbaumTarski

/-! ### Completeness -/

namespace Formula

variable {Var : Type*}

/-- The canonical valuation into the Lindenbaum–Tarski algebra: `p ↦ ⟦p⟧`. -/
def canonicalVal : Var → LindenbaumTarski Var :=
  fun p => toAntisymmetrization (· ≤ ·) (var p)

/-- Evaluating under the canonical valuation returns the formula's own class. -/
theorem eval_canonicalVal (φ : Formula Var) :
    eval canonicalVal φ = toAntisymmetrization (· ≤ ·) φ := by
  induction φ with
  | top => rfl
  | var p => rfl
  | neg φ ih => show (eval canonicalVal φ)ᶜ = _; rw [ih]; rfl
  | and φ ψ ihφ ihψ => show eval canonicalVal φ ⊓ eval canonicalVal ψ = _; rw [ihφ, ihψ]; rfl

end Formula

universe u

/-- **Completeness** ([holliday-mandelkern-2024] Theorem 3.13): if `φ ⊨ ψ` holds in
    every ortholattice under every valuation, then `φ ⊢ ψ`. Proved by evaluating in
    the Lindenbaum–Tarski algebra under the canonical valuation. (Testing
    ortholattices at `Var`'s universe suffices — the L–T algebra is the worst case.) -/
theorem complete {Var : Type u} {φ ψ : Formula Var}
    (h : ∀ {L : Type u} [OrthocomplementedLattice L] (v : Var → L),
      Formula.eval v φ ≤ Formula.eval v ψ) : φ ⊢ ψ := by
  have key := h (L := LindenbaumTarski Var) Formula.canonicalVal
  rw [Formula.eval_canonicalVal, Formula.eval_canonicalVal] at key
  exact LindenbaumTarski.mk_le_mk.mp key

/-- **Algebraic completeness of orthologic** ([holliday-mandelkern-2024]
    Theorem 3.13): `φ ⊢ ψ` iff the inequality holds in every ortholattice. -/
theorem derivable_iff {Var : Type u} {φ ψ : Formula Var} :
    φ ⊢ ψ ↔ ∀ {L : Type u} [OrthocomplementedLattice L] (v : Var → L),
      Formula.eval v φ ≤ Formula.eval v ψ := by
  refine ⟨fun h => ?_, complete⟩
  intro _ _ v
  exact sound h v

end Orthologic
