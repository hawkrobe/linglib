import Linglib.Core.Computability.Subregular.Basic

/-!
# Strictly Local Languages (SL_k)

A language `L` is **strictly `k`-local** when membership in `L` is
determined by which length-`k` substrings the boundary-augmented form
of the input contains @cite{rogers-pullum-2011} @cite{lambert-2022}.
The two equivalent presentations are:

- **Positive**: a set `G` of *permitted* `k`-factors. `w ∈ L` iff every
  `k`-factor of `boundary k w` is in `G`.
- **Negative**: a set `F` of *forbidden* `k`-factors. `w ∈ L` iff no
  `k`-factor of `boundary k w` is in `F`.

The negative form is what most phonological accounts use (forbidden bigrams,
forbidden trigrams), since it is finite even when the alphabet is infinite.

## This file

- `SLGrammar k α` — a positive `k`-grammar over alphabet `α`.
- `SLGrammar.lang` — the `Language α` (mathlib type) it generates.
- `SLGrammar.ofForbidden` — convert a forbidden-factor set to the
  equivalent positive grammar (over a finite alphabet).
- `SLGrammar.IsSLk` — the property that a `Language α` is strictly
  `k`-local for a given `k`.

The connection to `Mathlib.Computability.Language` is direct: an
`SLGrammar` *is* a `Language α` via `lang`.
-/

namespace Core.Computability.Subregular

universe u

variable {α : Type u}

-- ============================================================================
-- § 1: Strictly local grammar — positive presentation
-- ============================================================================

/-- A **strictly `k`-local grammar** over `α`: a set of *permitted*
    length-`k` factors, drawn from the boundary-augmented alphabet
    `Option α` (with `none` as the boundary). -/
structure SLGrammar (k : ℕ) (α : Type u) where
  /-- The set of permitted `k`-factors. Factors not listed here are
      forbidden in any string of the language. -/
  permitted : Set (Augmented α)

namespace SLGrammar

variable {k : ℕ}

/-- The language generated by an SL grammar: strings whose
    boundary-augmented form has every `k`-factor in `permitted`. -/
def lang (G : SLGrammar k α) : Language α :=
  fun w => ∀ f ∈ kFactorsList k (boundary k w), f ∈ G.permitted

/-- An SL grammar accepts `w` iff every `k`-factor of the
    boundary-augmented form is permitted. -/
@[simp] theorem mem_lang (G : SLGrammar k α) (w : List α) :
    w ∈ G.lang ↔ ∀ f ∈ kFactorsList k (boundary k w), f ∈ G.permitted :=
  Iff.rfl

-- ============================================================================
-- § 2: Forbidden-factor presentation
-- ============================================================================

/-- An SL grammar from a **forbidden**-factor set, given a decidable
    background of all possible factors over `α`. The permitted set is
    the universe minus the forbidden set; equivalently, a string is
    accepted iff none of its `k`-factors are in `forbidden`. -/
def ofForbidden (forbidden : Set (Augmented α)) : SLGrammar k α where
  permitted := forbiddenᶜ

@[simp] theorem mem_ofForbidden_lang (forbidden : Set (Augmented α))
    (w : List α) :
    w ∈ (ofForbidden (k := k) forbidden).lang
      ↔ ∀ f ∈ kFactorsList k (boundary k w), f ∉ forbidden := by
  simp [ofForbidden]

-- ============================================================================
-- § 3: Trivial SL grammars
-- ============================================================================

/-- The SL grammar permitting *all* factors — accepts every string. -/
def univ (k : ℕ) (α : Type u) : SLGrammar k α := ⟨Set.univ⟩

@[simp] theorem lang_univ (k : ℕ) :
    (univ k α).lang = (Set.univ : Language α) := by
  funext w
  exact propext ⟨fun _ => trivial, fun _ _ _ => trivial⟩

/-- The SL grammar permitting *no* factors — accepts only strings whose
    boundary-augmented form has no `k`-factor (i.e. shorter than `k`
    after padding). -/
def empty (k : ℕ) (α : Type u) : SLGrammar k α := ⟨∅⟩

@[simp] theorem mem_empty_lang_iff (w : List α) :
    w ∈ (empty k α).lang ↔ kFactorsList k (boundary k w) = [] := by
  refine ⟨fun h => ?_, fun h f hf => by rw [h] at hf; exact (List.not_mem_nil hf).elim⟩
  rcases hh : kFactorsList k (boundary k w) with _ | ⟨f, fs⟩
  · rfl
  · have hf : f ∈ kFactorsList k (boundary k w) := by rw [hh]; exact List.mem_cons_self ..
    exact absurd (h f hf) (Set.notMem_empty _)

end SLGrammar

-- ============================================================================
-- § 4: SL_k as a property of `Language α`
-- ============================================================================

/-- A language `L` is **strictly `k`-local** iff some `SLGrammar k α`
    generates exactly `L`. This is the witness-style definition (cf.
    "L is regular iff some DFA accepts L" in `Mathlib.Computability.DFA`). -/
def IsSLk (k : ℕ) (L : Language α) : Prop :=
  ∃ G : SLGrammar k α, G.lang = L

/-- Every SL grammar witnesses SL_k for its language. -/
theorem SLGrammar.isSLk_lang {k : ℕ} (G : SLGrammar k α) : IsSLk k G.lang :=
  ⟨G, rfl⟩

end Core.Computability.Subregular
