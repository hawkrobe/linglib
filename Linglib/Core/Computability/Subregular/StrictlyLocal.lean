import Linglib.Core.Computability.Subregular.Basic

/-!
# Strictly Local Languages (SL_k)

A language `L` is **strictly `k`-local** when membership in `L` is
determined by which length-`k` substrings the boundary-augmented form of
the input contains @cite{rogers-pullum-2011} @cite{lambert-2022}. The two
equivalent presentations are:

* **Positive**: a set `G` of *permitted* `k`-factors. `w Ôłł L` iff every
  `k`-factor of `boundary k w` is in `G`.
* **Negative**: a set `F` of *forbidden* `k`-factors. `w Ôłł L` iff no
  `k`-factor of `boundary k w` is in `F`.

The negative form is what most phonological accounts use (forbidden
bigrams, forbidden trigrams), since it is finite even when the alphabet
is infinite.

## Main definitions

* `SLGrammar k ╬▒` ÔÇö a positive `k`-grammar over alphabet `╬▒`.
* `SLGrammar.lang` ÔÇö the `Language ╬▒` (mathlib type) it generates.
* `SLGrammar.ofForbidden` ÔÇö convert a forbidden-factor set to the
  equivalent positive grammar.
* `IsStrictlyLocal k L` ÔÇö the property that a `Language ╬▒` is strictly
  `k`-local for a given `k`.
-/

namespace Core.Computability.Subregular

variable {╬▒ : Type*}

/-- A **strictly `k`-local grammar** over `╬▒`: a set of *permitted*
length-`k` factors over the boundary-augmented alphabet `Option ╬▒`
(with `none` as the boundary). -/
@[ext]
structure SLGrammar (k : ÔäĽ) (╬▒ : Type*) where
  /-- The set of permitted `k`-factors. Factors not listed here are
  forbidden in any string of the language. -/
  permitted : Set (Augmented ╬▒)

namespace SLGrammar

variable {k : ÔäĽ}

instance : Inhabited (SLGrammar k ╬▒) := ÔčĘÔčĘSet.univÔčęÔčę

/-- The language generated by an SL grammar: strings whose
boundary-augmented form has every `k`-factor in `permitted`. -/
def lang (G : SLGrammar k ╬▒) : Language ╬▒ :=
  fun w => ÔłÇ f Ôłł kFactors k (boundary k w), f Ôłł G.permitted

@[simp] lemma mem_lang (G : SLGrammar k ╬▒) (w : List ╬▒) :
    w Ôłł G.lang Ôćö ÔłÇ f Ôłł kFactors k (boundary k w), f Ôłł G.permitted :=
  Iff.rfl

/-- An SL grammar from a **forbidden**-factor set. The permitted set is
the complement; equivalently, a string is accepted iff none of its
`k`-factors are in `forbidden`. -/
def ofForbidden (forbidden : Set (Augmented ╬▒)) : SLGrammar k ╬▒ where
  permitted := forbiddenßÂť

@[simp] lemma mem_ofForbidden_lang (forbidden : Set (Augmented ╬▒))
    (w : List ╬▒) :
    w Ôłł (ofForbidden (k := k) forbidden).lang
      Ôćö ÔłÇ f Ôłł kFactors k (boundary k w), f Ôłë forbidden := by
  simp only [mem_lang, ofForbidden, Set.mem_compl_iff]

end SLGrammar

/-- A language `L` is **strictly `k`-local** iff some `SLGrammar k ╬▒`
generates exactly `L`. This is the witness-style definition (cf.
"L is regular iff some DFA accepts L" in `Mathlib.Computability.DFA`). -/
def IsStrictlyLocal (k : ÔäĽ) (L : Language ╬▒) : Prop :=
  Ôłâ G : SLGrammar k ╬▒, G.lang = L

/-- Every SL grammar witnesses `IsStrictlyLocal` for its language. -/
lemma SLGrammar.isStrictlyLocal_lang {k : ÔäĽ} (G : SLGrammar k ╬▒) :
    IsStrictlyLocal k G.lang :=
  ÔčĘG, rflÔčę

end Core.Computability.Subregular
