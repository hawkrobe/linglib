import Linglib.Semantics.Reference.Context.Tower
import Linglib.Semantics.Reference.Context.Shifts
import Linglib.Semantics.Attitudes.Doxastic
import Linglib.Semantics.Reference.ShiftedIndexicals

/-!
# Context Quantification
[schlenker-2003] [hintikka-1962]

Bridges world quantification (`Doxastic.lean`) and context shifting (`Shifts.lean`).

[schlenker-2003]'s key insight: attitude verbs quantify over *contexts*, not
just worlds. Standard Hintikka semantics (∀w'. R(x,w,w') → p(w')) is a special
case where only the world coordinate of the accessible context matters. In
languages with shifted indexicals (Amharic, Zazaki), the agent coordinate of
the accessible context carries semantic content that pure world quantification
cannot capture.

## Key Definitions

- `sayM`: monstrous say operator — attitude verb quantifying over contexts
- `ctxFromShift`: the accessible context generated by an attitude shift
- `ctxBox`: context quantification (Schlenker's primitive), the special case
  of `sayM` whose meaning reads only the innermost (shifted) context

## Key Results

- `sayM_reduces_to_box`: tower quantification with world-only meaning = `boxAt`
- `ctxBox_world_only`: context quantification with world-only meaning = `boxAt`
- `ctxBox_agent_sensitive`: context quantification provides agent information
  that world quantification cannot capture
- `doxastic_is_ctxBox_world_only`: `DoxasticPredicate.holdsAt` is veridicality + `ctxBox`
-/

namespace Semantics.Attitudes.ContextQuantification

open Semantics.Context
open Semantics.Attitudes.Doxastic (AccessRel boxAt)

variable {W : Type*} {E : Type*} {P : Type*} {T : Type*}

-- ════════════════════════════════════════════════════════════════
-- § Monstrous Say
-- ════════════════════════════════════════════════════════════════

/-- Monstrous attitude-verb semantics via tower push: for each world `w'`
    accessible via `R`, push an attitude shift onto the tower (the holder
    becomes the agent, `w'` the world) and evaluate `φ` against the shifted
    tower.

    This is the canonical monstrous `Say_m` of [schlenker-2003] — an attitude
    verb quantifying over accessible *contexts*, not just worlds. The
    quantifier ranges over a finite `worlds` list, the decidable rendering of
    Schlenker's unbounded context quantification (cf. `boxAt`). Because `φ`
    sees the whole shifted tower, it can resolve both origin-reading and
    local-reading indexicals; the special case where `φ` consults only the
    innermost (shifted) context is `ctxBox` below. -/
def sayM (R : AccessRel W E) (holder : E)
    (φ : ContextTower (KContext W E P T) → W → Prop)
    (t : ContextTower (KContext W E P T)) (w : W) (worlds : List W) : Prop :=
  ∀ w' ∈ worlds, R holder w w' → φ (t.push (attitudeShift holder w')) w'

-- ════════════════════════════════════════════════════════════════
-- § Shift-Generated Contexts
-- ════════════════════════════════════════════════════════════════

/-- The context produced by an attitude shift: push the shift onto the
    tower and read the innermost context. This is the "accessible context"
    that the embedded clause evaluates against.

    By `push_innermost`, this equals `(attitudeShift holder w').apply t.innermost`,
    i.e., `{ t.innermost with agent := holder, world := w' }`. -/
def ctxFromShift (t : ContextTower (KContext W E P T)) (holder : E) (w' : W) :
    KContext W E P T :=
  (t.push (attitudeShift holder w')).innermost

@[simp] theorem shift_world
    (t : ContextTower (KContext W E P T)) (holder : E) (w' : W) :
    (ctxFromShift t holder w').world = w' := by
  simp [ctxFromShift, attitudeShift]

@[simp] theorem shift_agent
    (t : ContextTower (KContext W E P T)) (holder : E) (w' : W) :
    (ctxFromShift t holder w').agent = holder := by
  simp [ctxFromShift, attitudeShift]

@[simp] theorem shift_time
    (t : ContextTower (KContext W E P T)) (holder : E) (w' : W) :
    (ctxFromShift t holder w').time = t.innermost.time := by
  simp [ctxFromShift, attitudeShift]

@[simp] theorem shift_position
    (t : ContextTower (KContext W E P T)) (holder : E) (w' : W) :
    (ctxFromShift t holder w').position = t.innermost.position := by
  simp [ctxFromShift, attitudeShift]

@[simp] theorem shift_addressee
    (t : ContextTower (KContext W E P T)) (holder : E) (w' : W) :
    (ctxFromShift t holder w').addressee = t.innermost.addressee := by
  simp [ctxFromShift, attitudeShift]

-- ════════════════════════════════════════════════════════════════
-- § Reduction: Tower Quantification → World Quantification
-- ════════════════════════════════════════════════════════════════

/-- When the embedded meaning ignores the context tower and depends only
    on the world, monstrous tower quantification reduces to standard
    Hintikka world quantification.

    The proof is `rfl`: with `φ = fun _ w' => p w'`, `sayM` and `boxAt`
    unfold to the same term. The ONLY difference between them is whether
    the meaning function can see the tower. -/
theorem sayM_reduces_to_box
    (R : AccessRel W E) (holder : E) (p : W → Prop)
    (t : ContextTower (KContext W E P T)) (w : W) (worlds : List W) :
    sayM R holder (fun _ w' => p w') t w worlds
    = boxAt R holder w worlds p := rfl

-- ════════════════════════════════════════════════════════════════
-- § Context Quantification (Direct)
-- ════════════════════════════════════════════════════════════════

/-- Context quantification: the special case of `sayM` whose meaning consults
    only the innermost (shift-generated) context.

    ⟦x V φ⟧(t, w) = ∀w' ∈ worlds. R(x,w,w') → φ(ctxFromShift t x w')

    This is [schlenker-2003]'s primitive: attitude verbs quantify over
    contexts ⟨holder, w', t, p⟩, not just worlds w'. Defined as `sayM` with
    `φ` factored through `.innermost` (which equals `ctxFromShift`), so the
    reduction and Fixity results below are specializations of `sayM`'s. -/
def ctxBox (R : AccessRel W E) (holder : E)
    (φ : KContext W E P T → Prop)
    (t : ContextTower (KContext W E P T)) (w : W) (worlds : List W) : Prop :=
  sayM R holder (fun tw _ => φ tw.innermost) t w worlds

instance ctxBox_decidable (R : AccessRel W E) [∀ a w w', Decidable (R a w w')]
    (holder : E) (φ : KContext W E P T → Prop) [DecidablePred φ]
    (t : ContextTower (KContext W E P T)) (w : W) (worlds : List W) :
    Decidable (ctxBox R holder φ t w worlds) :=
  inferInstanceAs (Decidable (∀ w' ∈ worlds, _))

/-- When φ depends only on the world coordinate, context quantification
    reduces to standard Hintikka world quantification (`boxAt`).

    This is the formal content of [schlenker-2003]'s observation:
    Hintikka semantics is a SPECIAL CASE of context quantification —
    the case where the embedded clause has no shifted indexicals, no
    perspective-dependent expressions, nothing that reads from the
    context beyond the world. -/
theorem ctxBox_world_only
    (R : AccessRel W E) (holder : E) (p : W → Prop)
    (t : ContextTower (KContext W E P T)) (w : W) (worlds : List W) :
    ctxBox R holder (fun c => p c.world) t w worlds
    = boxAt R holder w worlds p := by
  simp only [ctxBox, sayM, boxAt, ContextTower.push_innermost, attitudeShift_changes_world]

-- ════════════════════════════════════════════════════════════════
-- § Non-Reduction: Context-Sensitive Meanings
-- ════════════════════════════════════════════════════════════════

/-- Context quantification provides information that world quantification
    cannot capture: the identity of the attitude holder as agent.

    In shift languages (Amharic, Zazaki), the embedded first person pronoun
    reads `.agent` from the accessible context. Under `ctxBox`, this yields
    the attitude holder. Under `boxAt`, there is no agent to read — the
    meaning is `W → Bool`, not `KContext → Bool`.

    This is why monsters matter: `ctxBox` with agent-sensitive φ is strictly
    more expressive than `boxAt`. -/
theorem ctxBox_agent_sensitive
    (t : ContextTower (KContext W E P T)) (holder : E) (w' : W)
    (hDiff : t.innermost.agent ≠ holder) :
    (ctxFromShift t holder w').agent = holder ∧
    (ctxFromShift t holder w').agent ≠ t.innermost.agent :=
  ⟨shift_agent t holder w', by rw [shift_agent]; exact hDiff.symm⟩

-- ════════════════════════════════════════════════════════════════
-- § Bridge to DoxasticPredicate
-- ════════════════════════════════════════════════════════════════

/-- `DoxasticPredicate.holdsAt` is a veridicality check plus `ctxBox`
    with world-projected meaning.

    This connects the modular `DoxasticPredicate` API (`Doxastic.lean`)
    to context quantification: every doxastic predicate IS context
    quantification over world-only propositions, with an additional
    veridicality constraint at the evaluation world. -/
theorem doxastic_is_ctxBox_world_only
    (V : Doxastic.DoxasticPredicate W E) (agent : E) (p : W → Prop)
    (w : W) (worlds : List W) (t : ContextTower (KContext W E P T)) :
    V.holdsAt agent p w worlds ↔
    (Doxastic.veridicalityHolds V.veridicality p w ∧
     ctxBox V.access agent (fun c => p c.world) t w worlds) := by
  simp only [Doxastic.DoxasticPredicate.holdsAt, ctxBox_world_only]

-- ════════════════════════════════════════════════════════════════
-- § Fixity Thesis ([schlenker-2003], Claim 2)
-- ════════════════════════════════════════════════════════════════

/-- The Fixity Thesis ([schlenker-2003], Appendix):
    a tower-parameterized meaning satisfies Fixity iff its
    truth value is the same regardless of the tower configuration.

    In [schlenker-2003]'s formulation: ⟦φ⟧^{c,i} is independent
    of c. In the tower analysis: the meaning function ignores the
    tower parameter entirely.

    The thesis holds in standard (non-monstrous) formal semantics where
    sentences have world-dependent but context-independent denotations.
    It fails in [schlenker-2003]'s MEL (Monstrous Egli Language),
    where attitude operators bind context variables that shift indexical
    reference. -/
def SatisfiesFixity (φ : ContextTower (KContext W E P T) → W → Prop) : Prop :=
  ∀ (t₁ t₂ : ContextTower (KContext W E P T)) (w : W), φ t₁ w = φ t₂ w

/-- World-only meanings satisfy the Fixity Thesis. These are the
    non-monstrous meanings: their truth value depends only on the
    evaluation world, not on who uttered the sentence or how deeply
    embedded it is.

    This captures the "easy direction" of Claim 2: in a language
    without monsters, every meaning is world-only, so Fixity holds. -/
theorem fixity_world_only (p : W → Prop) :
    SatisfiesFixity (W := W) (E := E) (P := P) (T := T)
      (fun _ w => p w) :=
  fun _ _ _ => rfl

/-- Context quantification preserves Fixity: if the embedded meaning
    depends only on the world coordinate, `ctxBox` produces the same
    result regardless of which tower it is evaluated against.

    This is because `ctxBox` with world-only meaning reduces to
    `boxAt` (by `ctxBox_world_only`), which is tower-independent. -/
theorem ctxBox_fixity (R : AccessRel W E) (holder : E)
    (p : W → Prop)
    (t₁ t₂ : ContextTower (KContext W E P T))
    (w : W) (worlds : List W) :
    ctxBox R holder (fun c => p c.world) t₁ w worlds =
    ctxBox R holder (fun c => p c.world) t₂ w worlds := by
  simp only [ctxBox_world_only]

-- ════════════════════════════════════════════════════════════════
-- § Bridge to Shifted Indexicals
-- ════════════════════════════════════════════════════════════════

open Semantics.Reference.ShiftedIndexicals (amharic_pronI)
open Semantics.Reference.Kaplan (pronI_access pronI_shift_invariant)

/-- The agent of the accessible context equals what Amharic "I"
    (`amharic_pronI`) reads from the shifted tower.

    This connects context quantification (`ctxFromShift`) to the
    shifted indexical framework: both pick out the attitude holder
    as the referent of the embedded first person. -/
theorem ctxFromShift_agent_eq_amharic_I
    (t : ContextTower (KContext W E P T)) (holder : E) (w' : W) :
    (ctxFromShift t holder w').agent =
    amharic_pronI.resolve (t.push (attitudeShift holder w')) := by
  simp only [ctxFromShift, amharic_pronI, AccessPattern.resolve,
    DepthSpec.local_resolve, ContextTower.contextAt_depth]

/-- English "I" (`pronI_access`) is invariant under the attitude shift
    used by `ctxBox` — it always returns the origin agent (actual
    speaker), not the attitude holder. -/
theorem english_I_invariant
    (t : ContextTower (KContext W E P T)) (holder : E) (w' : W) :
    pronI_access.resolve (t.push (attitudeShift holder w')) =
    pronI_access.resolve t :=
  pronI_shift_invariant t (attitudeShift holder w')

end Semantics.Attitudes.ContextQuantification
